# ═══════════════════════════════════════════════════════════════
# Backend Environment Variables
# 复制此文件为 backend/.env 并填入实际值
# FastAPI 通过 backend/app/config.py (Pydantic Settings) 读取
# ═══════════════════════════════════════════════════════════════

# ── 应用安全 (必填) ───────────────────────────────────────────
APP_ID=                   # OAuth / 开放平台应用 ID
APP_SECRET=               # 应用密钥（同时用于 JWT 签名）

# ── 数据库 (必填) ─────────────────────────────────────────────
# 格式: mysql://用户名:密码@主机:端口/数据库名
# 示例: mysql://root:123456@localhost:3306/kimi_blog
DATABASE_URL=

# ── Kimi OAuth 认证 ───────────────────────────────────────────
KIMI_AUTH_URL=            # Kimi 授权服务端地址（如 https://auth.kimi.com）
KIMI_OPEN_URL=            # Kimi 开放平台 API 地址（如 https://open.kimi.com）

# ── 管理员设置 (可选但建议配置) ────────────────────────────────
OWNER_UNION_ID=           # 首次登录时自动赋予 admin 角色的用户 Union ID
